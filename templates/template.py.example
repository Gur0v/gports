# Copy this directory to user/<package-name>, then fill in every placeholder.
pkgname = "example"
pkgver = "0.0.0"
pkgrel = 0
build_style = "configure"
hostmakedepends = ["pkgconf"]
makedepends = []
depends = []
pkgdesc = "One-line package description"
license = "MIT"
url = "https://example.invalid"
source = f"$url/archive/v{pkgver}.tar.gz"
sha256 = "REPLACE_WITH_CBUILD_GENERATED_SHA256"


def post_install(self):
    self.install_license("LICENSE")
