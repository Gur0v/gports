@@ -0,0 +1,15 @@
+from pathlib import Path
+
+
+root = Path(__file__).parents[1] / "src" / "ugrd"
+source = "\n".join(
+    path.read_text() for path in root.rglob("*") if path.suffix in {".py", ".toml"}
+)
+
+assert "grep" not in source
+assert '== "$1"' not in source
+assert "for arg in $(cat /proc/cmdline)" not in source
+assert "rm -rfv" not in source
+assert "mkdir -pv" not in source
+assert "read -p" not in source
+assert "[ -r /proc/mounts ] || return 1" in source
