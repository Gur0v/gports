#!/bin/sh
# Expose gports templates to the sibling cports checkout for one cbuild command.
set -eu

root=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
cports=${CPORTS_DIR:-"$root/../cports"}
config="$root/etc/config.ini"

usage() {
    echo "usage: $0 <cbuild-command> user/<package> [cbuild options]" >&2
    echo "       $0 bootstrap" >&2
    exit "${1:-0}"
}

[ -x "$cports/cbuild" ] || {
    echo "gbuild: cbuild not found at $cports (set CPORTS_DIR)" >&2
    exit 1
}

run_cbuild() {
    "$cports/cbuild" \
        --config "$config" \
        --build-root "$root/bldroot" \
        --repository-path "$root/packages" \
        --stage-path "$root/pkgstage" \
        --sources-path "$root/sources" \
        "$@"
}

[ "$#" -gt 0 ] || usage 1
case "$1" in
    -h|--help|help) usage ;;
    bootstrap)
        run_cbuild bootstrap
        exit
        ;;
esac

[ "$#" -ge 2 ] || usage 1
command=$1
template=$2
shift 2

case "$template" in
    user/*)
        package=${template#user/}
        [ -n "$package" ] && [ "$package" = "${package#*/}" ] || usage 1
        ;;
    *)
        echo "gbuild: templates must be addressed as user/<package>" >&2
        exit 1
        ;;
esac

[ -f "$root/$template/template.py" ] || {
    echo "gbuild: missing $root/$template/template.py" >&2
    exit 1
}

links=""
cleanup() {
    for package in $links; do
        rm -f "$cports/user/$package"
    done
}
trap cleanup EXIT HUP INT TERM

for package_dir in "$root"/user/*; do
    [ -f "$package_dir/template.py" ] || continue
    package=${package_dir##*/}
    link="$cports/user/$package"
    if [ -e "$link" ] || [ -L "$link" ]; then
        echo "gbuild: $link already exists; package name collides with cports" >&2
        exit 1
    fi
    ln -s "$package_dir" "$link"
    links="$links $package"
done

run_cbuild "$command" "$template" "$@"
